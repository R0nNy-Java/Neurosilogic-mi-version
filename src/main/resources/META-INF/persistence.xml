<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

  <persistence-unit name="NurseLogicPU" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <class>com.rrparedes.model.Usuario</class>
    <class>com.rrparedes.model.Paciente</class>
    <class>com.rrparedes.model.Medicamento</class>
    <class>com.rrparedes.model.PrescripcionMedica</class>
    <class>com.rrparedes.model.AdministracionMedicamento</class>
    <class>com.rrparedes.model.AuditoriaAcceso</class>
    <class>com.rrparedes.model.Antecedente</class>
    <class>com.rrparedes.model.SignoVital</class>
    <class>com.rrparedes.model.EscalaGlasgow</class>

    <properties>
      <!-- Configuración de Conexión MySQL -->
      <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
      <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/nurselogic_db?useSSL=false&amp;serverTimezone=UTC&amp;allowPublicKeyRetrieval=true"/>
      <property name="jakarta.persistence.jdbc.user" value="root"/>
      <property name="jakarta.persistence.jdbc.password" value="Arielito1235````````````````"/>

      <!-- Propiedades Hibernate -->
      <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>
      <property name="hibernate.hbm2ddl.auto" value="update"/>
    </properties>
  </persistence-unit>

</persistence>
